# ── EchoMind Backend Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values. Never commit .env!

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Database (PostgreSQL)
DATABASE_URL=postgresql://echomind:echomind@localhost:5432/echomind

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=echomind_docs

# App
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_ENV=development
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# Upload limits
MAX_UPLOAD_SIZE_MB=20
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5
